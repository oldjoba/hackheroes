############################################################
# Hack Heroes — self-hosted stack environment
# ----------------------------------------------------------
# These are LOCAL DEV credentials for running the whole stack
# (Postgres + Supabase services + the static site) in Docker.
# They are intentionally committed so `docker compose up` works
# out of the box. DO NOT reuse these values for a public
# deployment — generate your own secrets for anything exposed
# to the internet.
############################################################

# --- Postgres ---
POSTGRES_PASSWORD=hackheroes-dev-postgres-pw
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# --- JWT (shared secret used by GoTrue, PostgREST, Realtime) ---
JWT_SECRET=hackheroes-super-secret-dev-jwt-secret-min-32-chars-long-0001
JWT_EXPIRY=3600

# anon + service_role keys derived from JWT_SECRET above
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwiaWF0IjoxNzA0MDY3MjAwLCJleHAiOjIwMTk2NjcyMDAsInJvbGUiOiJhbm9uIn0.27yAQryhuU2kTej08soR0beq_Kyad3reNxqXvwYQZVE
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwiaWF0IjoxNzA0MDY3MjAwLCJleHAiOjIwMTk2NjcyMDAsInJvbGUiOiJzZXJ2aWNlX3JvbGUifQ.aNz9ykNuOLKiGMY_fszQIfiQQEcezpJHCIpVCVVBORs

# --- Public URLs (as seen from the browser) ---
# The site is served by nginx on :8080; nginx also reverse-proxies
# the Supabase gateway, so the browser only ever talks to :8080.
SITE_URL=http://localhost:8080
API_EXTERNAL_URL=http://localhost:8080
SUPABASE_PUBLIC_URL=http://localhost:8080

# --- GoTrue (auth) ---
# Allow anonymous sign-ins (students) and disable email confirmation so
# teacher accounts work immediately in local dev (no SMTP server).
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_EXTERNAL_ANONYMOUS_USERS_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_SMTP_ADMIN_EMAIL=admin@hackhero.local
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_SENDER_NAME=Hack Heroes

# --- Realtime tenant ---
# supabase-js derives the tenant id from the site URL host. With
# SUPABASE_PUBLIC_URL=http://localhost:8080 that id is "localhost".
TENANT_EXTERNAL_ID=localhost
