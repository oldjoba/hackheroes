# Self-contained Hack Heroes database image.
FROM supabase/postgres:15.1.1.78
COPY zzz-hackheroes-schema.sql /docker-entrypoint-initdb.d/zzz-hackheroes-schema.sql
# Sets service-role passwords AS supabase_admin at init (no db-setup container
# needed) so the stack can run as single-container Easypanel App services.
COPY zzz-zzz-roles.sh /docker-entrypoint-initdb.d/zzz-zzz-roles.sh
